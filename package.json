{
  "name": "license-wizard",
  "version": "1.0.0-dev",
  "description": "An interactive CLI for generating license files",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.13.0"
  },
  "author": "Erdem Bircan",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erdembircan/license-wizard.git"
  },
  "homepage": "https://github.com/erdembircan/license-wizard#readme",
  "bugs": "https://github.com/erdembircan/license-wizard/issues",
  "bin": {
    "license-wizard": "bin/license-wizard.js"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "dev:start": "pnpm run build && chmod +x bin/license-wizard.js && bin/license-wizard.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  }
}
