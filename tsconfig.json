{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@cli/*": ["src/cli/*"],
      "@licensing/*": ["src/licensing/*"],
      "@configuration/*": ["src/configuration/*"]
    }
  },
  "include": ["src/**/*.ts", "vitest.config.ts"]
}
